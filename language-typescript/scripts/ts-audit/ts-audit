#!/usr/bin/env bash
set -euo pipefail

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"

usage() {
  echo "Usage: ts-audit [--last-commit | --working-tree | --staged | --commit <sha> | --range <from> <to>] [path]"
  echo ""
  echo "Modes:"
  echo "  --last-commit    Lint files changed in the last commit"
  echo "  --commit <sha>   Lint files changed in a specific commit"
  echo "  --range <from> <to>  Lint files changed between two commits"
  echo "  --working-tree   Lint files modified in the working tree"
  echo "  --staged         Lint staged files only"
  echo "  (no flag)        Lint all files in path (default: .)"
  exit 0
}

MODE="all"
TARGET=""
COMMIT_SHA=""
RANGE_FROM=""
RANGE_TO=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --last-commit) MODE="last-commit"; shift ;;
    --commit) MODE="commit"; COMMIT_SHA="$2"; shift 2 ;;
    --range) MODE="range"; RANGE_FROM="$2"; RANGE_TO="$3"; shift 3 ;;
    --working-tree) MODE="working-tree"; shift ;;
    --staged) MODE="staged"; shift ;;
    -h|--help) usage ;;
    *) TARGET="$1"; shift ;;
  esac
done

PKG_RUNNER=$(command -v bunx >/dev/null 2>&1 && echo "bunx" || echo "npx")

# Build config: inject absolute sonarjs path into template
TMP_CONFIG=$(mktemp /tmp/oxlintrc.XXXXXX.json)
sed -e "s|__SONARJS_PATH__|$SKILL_DIR/node_modules/eslint-plugin-sonarjs|" \
    -e "s|__JSDOC_PATH__|$SKILL_DIR/node_modules/eslint-plugin-jsdoc|" \
    "$SKILL_DIR/oxlintrc.json" > "$TMP_CONFIG"
trap 'rm -f "$TMP_CONFIG"' EXIT

get_files() {
  local diff_args="$1"
  eval "git diff $diff_args --name-only --diff-filter=d --relative" | grep -E '\.(ts|tsx|js|jsx|mts|mjs|vue)$' || true
}

lint_files() {
  local files="$1"
  local label="$2"
  if [[ -z "$files" ]]; then
    echo "No TS/JS/Vue files changed in $label."
    exit 0
  fi
  echo "$files" | xargs $PKG_RUNNER oxlint@latest --vue-plugin --fix -c "$TMP_CONFIG"
}

case "$MODE" in
  last-commit)
    lint_files "$(get_files "HEAD~1")" "last commit"
    ;;
  commit)
    lint_files "$(get_files "${COMMIT_SHA}~1 ${COMMIT_SHA}")" "commit ${COMMIT_SHA}"
    ;;
  range)
    lint_files "$(get_files "${RANGE_FROM} ${RANGE_TO}")" "range ${RANGE_FROM}..${RANGE_TO}"
    ;;
  working-tree)
    lint_files "$(get_files "")" "working tree"
    ;;
  staged)
    lint_files "$(get_files "--cached")" "staged files"
    ;;
  all)
    $PKG_RUNNER oxlint@latest --vue-plugin --fix -c "$TMP_CONFIG" "${TARGET:-.}"
    ;;
esac
